{
  "expo": {
    "name": "StudentOS",
    "slug": "studentos",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "studentos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#7c3aed"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.studentos.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7c3aed"
      },
      "package": "com.studentos.app",
      "permissions": [
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "RECORD_AUDIO",
        "CAMERA",
        "PACKAGE_USAGE_STATS",
        "SYSTEM_ALERT_WINDOW"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "expo-camera",
      "expo-font"
    ],
    "extra": {
      "supabaseUrl": "https://aubastwqendcpwwbusgs.supabase.co",
